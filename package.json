{
  "name": "tethermark",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build --silent && node dist/packages/core-engine/src/test-runner.js",
    "exports:check": "npm run build --silent && node dist/packages/core-engine/src/export-maintenance.js check",
    "exports:refresh": "npm run build --silent && node dist/packages/core-engine/src/export-maintenance.js refresh",
    "release:check": "npm run build --silent && npm test --silent && npm run exports:check && npm run scan -- validate-fixtures",
    "oss": "npm run build --silent && node scripts/run-api-web.mjs",
    "oss:check": "npm run build --silent && node scripts/check-oss.mjs",
    "scan": "npm run build --silent && node dist/apps/cli/src/index.js",
    "scan:self": "npm run build --silent && node dist/apps/cli/src/index.js scan path . --output ./.artifacts/runs/self-scan-ts --mode static",
    "api": "npm run build --silent && node dist/apps/api-server/src/index.js",
    "mcp": "npm run build --silent && node dist/apps/mcp-server/src/index.js",
    "web": "npm run build --silent && node dist/apps/web-ui/src/index.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0"
  }
}
