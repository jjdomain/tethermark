AUDIT_LLM_PROVIDER=mock
AUDIT_LLM_MODEL=mock-agent-runtime
AUDIT_LLM_API_KEY=

# OpenAI Codex local/OAuth mode. Set AUDIT_LLM_PROVIDER=openai_codex after
# installing Codex CLI and signing in with ChatGPT/Codex locally.
AUDIT_LLM_CODEX_COMMAND=codex
AUDIT_LLM_CODEX_MODEL=gpt-5.1-codex
AUDIT_LLM_CODEX_SANDBOX=read-only
AUDIT_LLM_CODEX_TIMEOUT_MS=600000
HARNESS_ENABLE_LOCAL_OAUTH_CONNECT=

# OSS runtime defaults
PORT=8787
WEB_UI_PORT=8788
WEB_UI_API_BASE_URL=http://127.0.0.1:8787

# OSS auth model
HARNESS_API_AUTH_MODE=none
HARNESS_API_KEY=

# Persistence mode
# OSS supports SQLite-backed local storage only.
HARNESS_DB_MODE=local
HARNESS_LOCAL_DB_ROOT=

# Runtime/tooling toggles
PYTHON_BIN=python
HARNESS_DISABLE_LOCAL_BINARIES=0
HARNESS_DISABLE_PYTHON_WORKERS=0
HARNESS_ENABLE_HOST_SANDBOX_EXECUTION=0
HARNESS_SANDBOX_STEP_TIMEOUT_MS=

# Optional bundle export tuning
HARNESS_BUNDLE_EXPORT_ENABLED=
HARNESS_BUNDLE_EXPORT_RETENTION_DAYS=

# Optional artifact pruning defaults used by `npm run scan -- artifacts prune`.
# Pruning is explicit; these settings do not delete artifacts unless the command is run.
HARNESS_ARTIFACT_RETENTION_DAYS=
HARNESS_ARTIFACT_RETENTION_MAX_GB=
HARNESS_ARTIFACT_RETENTION_KIND=runs

# Agent-specific overrides. Set provider, model, and key per agent when needed.
AUDIT_LLM_PLANNER_PROVIDER=
AUDIT_LLM_PLANNER_MODEL=
AUDIT_LLM_PLANNER_API_KEY=

AUDIT_LLM_THREAT_MODEL_PROVIDER=
AUDIT_LLM_THREAT_MODEL_MODEL=
AUDIT_LLM_THREAT_MODEL_API_KEY=

AUDIT_LLM_EVIDENCE_SELECTION_PROVIDER=
AUDIT_LLM_EVIDENCE_SELECTION_MODEL=
AUDIT_LLM_EVIDENCE_SELECTION_API_KEY=

AUDIT_LLM_SUPERVISOR_PROVIDER=
AUDIT_LLM_SUPERVISOR_MODEL=
AUDIT_LLM_SUPERVISOR_API_KEY=

AUDIT_LLM_AREA_REVIEW_PROVIDER=
AUDIT_LLM_AREA_REVIEW_MODEL=
AUDIT_LLM_AREA_REVIEW_API_KEY=

AUDIT_LLM_REMEDIATION_PROVIDER=
AUDIT_LLM_REMEDIATION_MODEL=
AUDIT_LLM_REMEDIATION_API_KEY=
